{
  "components": {
    "schemas": {
      "BulkEntryActionDto": {
        "properties": {
          "action": {
            "description": "Action to apply to every id.",
            "enum": [
              "approve",
              "reject",
              "invite-to-app"
            ],
            "example": "approve",
            "type": "string"
          },
          "appSlug": {
            "description": "Heimdall app slug override for `action: invite-to-app`. When omitted, falls back to `rally_settings.default_heimdall_app_slug`. Ignored for approve/reject.",
            "example": "acme-product",
            "maxLength": 64,
            "type": "string"
          },
          "ids": {
            "description": "Entry UUIDs to act on in this batch. Capped at 100 per call; the request is processed serially and per-row results are returned. De-duped server-side.",
            "example": [
              "11111111-1111-1111-1111-111111111111",
              "22222222-2222-2222-2222-222222222222"
            ],
            "items": {
              "type": "string"
            },
            "maxItems": 100,
            "minItems": 1,
            "type": "array"
          },
          "sendEmail": {
            "default": true,
            "description": "Whether to send the rally/approved email with the invite link baked in. Defaults to `true`. Ignored for approve/reject.",
            "type": "boolean"
          }
        },
        "required": [
          "ids",
          "action"
        ],
        "type": "object"
      },
      "CreateEntryDto": {
        "properties": {
          "email": {
            "description": "Email address",
            "example": "ada@example.com",
            "type": "string"
          },
          "interest": {
            "description": "Free-text product interest",
            "type": "string"
          },
          "metadata": {
            "description": "Custom field values",
            "type": "object"
          },
          "name": {
            "description": "Full name",
            "example": "Ada Lovelace",
            "type": "string"
          },
          "recaptchaToken": {
            "description": "reCAPTCHA v3 token; verified server-side when the waitlist has settings.recaptcha_site_key",
            "type": "string"
          },
          "referralCode": {
            "description": "Referral code from a prior signup; bumps that signup’s position when honoured",
            "type": "string"
          },
          "referrer": {
            "description": "How they heard about it",
            "type": "string"
          },
          "variantId": {
            "description": "Variant id this submission was attributed to. The hosted public page resolves this server-side and the embeddable widget reads it from the public payload — both round-trip it here so per-variant conversion can be computed without a separate impressions table.",
            "format": "uuid",
            "type": "string"
          }
        },
        "required": [
          "email",
          "name"
        ],
        "type": "object"
      },
      "CreateVariantDto": {
        "properties": {
          "active": {
            "default": true,
            "type": "boolean"
          },
          "copy": {
            "allOf": [
              {
                "$ref": "#/components/schemas/VariantCopyDto"
              }
            ],
            "description": "Copy overrides. Recognised keys: display_name, description, confirmation_message. Unknown keys are dropped on the public render."
          },
          "kind": {
            "enum": [
              "ab",
              "locale"
            ],
            "type": "string"
          },
          "locale": {
            "description": "BCP-47 locale tag. For ab variants this is the locale they target; for locale variants this is the locale they serve. Case is normalised on the public side.",
            "example": "en",
            "type": "string"
          },
          "weight": {
            "default": 1,
            "description": "Relative weight inside the ab pool. Ignored when kind=locale. Default 1.",
            "maximum": 100,
            "minimum": 1,
            "type": "number"
          }
        },
        "required": [
          "kind",
          "locale",
          "copy"
        ],
        "type": "object"
      },
      "CreateWaitlistDto": {
        "properties": {
          "description": {
            "description": "Description shown on the public page",
            "type": "string"
          },
          "displayName": {
            "description": "Display name",
            "example": "Early Access Program",
            "type": "string"
          },
          "settings": {
            "description": "Waitlist settings (max_entries, approval_required, custom_fields, confirmation_message, referral_boost)",
            "type": "object"
          },
          "slug": {
            "description": "URL-safe slug",
            "example": "early-access",
            "type": "string"
          }
        },
        "required": [
          "slug",
          "displayName"
        ],
        "type": "object"
      },
      "CreateWebhookDto": {
        "properties": {
          "active": {
            "description": "Disabled webhooks store events but never deliver",
            "type": "boolean"
          },
          "events": {
            "description": "Events to subscribe to",
            "example": [
              "entry.created",
              "entry.approved"
            ],
            "items": {
              "enum": [
                "entry.created",
                "entry.approved",
                "entry.rejected"
              ],
              "type": "string"
            },
            "type": "array"
          },
          "url": {
            "description": "Destination URL (must be https in prod)",
            "type": "string"
          }
        },
        "required": [
          "url",
          "events"
        ],
        "type": "object"
      },
      "InviteToAppDto": {
        "properties": {
          "appSlug": {
            "description": "Heimdall app slug to invite into; defaults to rally_settings.default_heimdall_app_slug",
            "type": "string"
          },
          "sendEmail": {
            "default": true,
            "description": "Send the rally/approved email with the Heimdall invite link baked in",
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "TestWebhookDto": {
        "properties": {
          "event": {
            "description": "Event type to fire as a synthetic test",
            "enum": [
              "entry.created",
              "entry.approved",
              "entry.rejected"
            ],
            "type": "string"
          }
        },
        "required": [
          "event"
        ],
        "type": "object"
      },
      "UpdateEntryStatusDto": {
        "properties": {
          "status": {
            "description": "Target status",
            "enum": [
              "approved",
              "rejected"
            ],
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "type": "object"
      },
      "UpdateSettingsDto": {
        "properties": {
          "brandLogoUrl": {
            "description": "Logo URL shown on public pages",
            "type": "string"
          },
          "brandName": {
            "description": "Brand name shown on public pages",
            "type": "string"
          },
          "defaultHeimdallAppSlug": {
            "description": "Heimdall consumer-app slug to invite approved entries into. null clears the link.",
            "nullable": true,
            "type": "string"
          },
          "defaultSenderDomainId": {
            "description": "Envoi (mailbox-api) domain UUID to use as default sender for Rally notifications. null clears the override.",
            "nullable": true,
            "type": "string"
          },
          "primaryColor": {
            "description": "Primary brand colour as #RRGGBB",
            "type": "string"
          }
        },
        "type": "object"
      },
      "UpdateVariantDto": {
        "properties": {
          "active": {
            "type": "boolean"
          },
          "copy": {
            "$ref": "#/components/schemas/VariantCopyDto"
          },
          "locale": {
            "type": "string"
          },
          "weight": {
            "maximum": 100,
            "minimum": 1,
            "type": "number"
          }
        },
        "type": "object"
      },
      "UpdateWaitlistDto": {
        "properties": {
          "description": {
            "description": "New description",
            "type": "string"
          },
          "displayName": {
            "description": "New display name",
            "type": "string"
          },
          "settings": {
            "description": "Updated settings (merged shallow)",
            "type": "object"
          }
        },
        "type": "object"
      },
      "UpdateWaitlistStatusDto": {
        "properties": {
          "status": {
            "description": "New status",
            "enum": [
              "draft",
              "active",
              "paused",
              "closed"
            ],
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "type": "object"
      },
      "UpdateWebhookDto": {
        "properties": {
          "active": {
            "description": "Pause/resume the webhook",
            "type": "boolean"
          },
          "events": {
            "description": "New event subscription",
            "items": {
              "enum": [
                "entry.created",
                "entry.approved",
                "entry.rejected"
              ],
              "type": "string"
            },
            "type": "array"
          },
          "url": {
            "description": "New URL",
            "type": "string"
          }
        },
        "type": "object"
      },
      "VariantCopyDto": {
        "properties": {
          "confirmation_message": {
            "maxLength": 500,
            "type": "string"
          },
          "description": {
            "maxLength": 1000,
            "type": "string"
          },
          "display_name": {
            "maxLength": 200,
            "type": "string"
          }
        },
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearer": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {},
    "description": "Waitlist management for the ProductCraft platform",
    "title": "Rally",
    "version": "0.1.0"
  },
  "openapi": "3.0.0",
  "paths": {
    "/v1/waitlists/{workspaceSlug}/{waitlistSlug}": {
      "get": {
        "operationId": "PublicWaitlistController_getPublic",
        "parameters": [
          {
            "in": "path",
            "name": "workspaceSlug",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "waitlistSlug",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "BCP-47 locale tag (e.g. `en`, `pt-BR`). Wins over Accept-Language when picking the variant.",
            "in": "query",
            "name": "lang",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Public waitlist info"
          },
          "404": {
            "description": "Waitlist not found or not active"
          }
        },
        "summary": "Public waitlist info (display name, description, custom-field schema, branding hints, active variant)",
        "tags": [
          "public-waitlist"
        ]
      }
    },
    "/v1/waitlists/{workspaceSlug}/{waitlistSlug}/entries": {
      "post": {
        "operationId": "PublicWaitlistController_submit",
        "parameters": [
          {
            "in": "path",
            "name": "workspaceSlug",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "waitlistSlug",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEntryDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Entry created"
          },
          "400": {
            "description": "Validation or spam check failed"
          },
          "404": {
            "description": "Waitlist not found"
          },
          "409": {
            "description": "Email already on this waitlist"
          },
          "422": {
            "description": "Waitlist is not active or is full"
          },
          "429": {
            "description": "Too many requests from this IP"
          }
        },
        "summary": "Submit a new entry to a public waitlist",
        "tags": [
          "public-waitlist"
        ]
      }
    },
    "/v1/waitlists/{workspaceSlug}/{waitlistSlug}/leaderboard": {
      "get": {
        "operationId": "PublicWaitlistController_leaderboard",
        "parameters": [
          {
            "in": "path",
            "name": "workspaceSlug",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "waitlistSlug",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Number of rows (1-50, default 50)",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of `{ position, referral_count, masked_email }`"
          },
          "404": {
            "description": "Waitlist not found or not active"
          }
        },
        "summary": "Public top-50 referral leaderboard. Emails are masked. Anonymous read; same access policy as the public waitlist info endpoint.",
        "tags": [
          "public-waitlist"
        ]
      }
    },
    "/v1/workspaces/{workspaceId}/rally/settings": {
      "get": {
        "operationId": "SettingsController_get",
        "parameters": [
          {
            "in": "path",
            "name": "workspaceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Read workspace-level Rally defaults",
        "tags": [
          "rally-settings"
        ]
      },
      "put": {
        "operationId": "SettingsController_update",
        "parameters": [
          {
            "in": "path",
            "name": "workspaceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSettingsDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Update workspace-level Rally defaults",
        "tags": [
          "rally-settings"
        ]
      }
    },
    "/v1/workspaces/{workspaceId}/waitlists": {
      "get": {
        "operationId": "WaitlistController_list",
        "parameters": [
          {
            "in": "path",
            "name": "workspaceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 20,
              "maximum": 100,
              "minimum": 1,
              "type": "number"
            }
          },
          {
            "description": "Opaque cursor for pagination",
            "in": "query",
            "name": "cursor",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Filter by status",
            "in": "query",
            "name": "status",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "List waitlists in this workspace",
        "tags": [
          "waitlists"
        ]
      },
      "post": {
        "operationId": "WaitlistController_create",
        "parameters": [
          {
            "in": "path",
            "name": "workspaceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWaitlistDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Waitlist created."
          },
          "400": {
            "description": "Validation failure."
          },
          "403": {
            "description": "Caller lacks `waitlist.create`, or workspace has not enabled the `rally` service."
          },
          "409": {
            "description": "Slug already taken in this workspace."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Create a waitlist (workspace-scoped)",
        "tags": [
          "waitlists"
        ]
      }
    },
    "/v1/workspaces/{workspaceId}/waitlists/{id}": {
      "delete": {
        "operationId": "WaitlistController_remove",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Waitlist deleted."
          },
          "403": {
            "description": "Caller lacks `waitlist.delete`."
          },
          "404": {
            "description": "Waitlist not found."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Delete a waitlist (cascades to entries)",
        "tags": [
          "waitlists"
        ]
      },
      "get": {
        "operationId": "WaitlistController_get",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get waitlist details",
        "tags": [
          "waitlists"
        ]
      },
      "patch": {
        "operationId": "WaitlistController_update",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateWaitlistDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Waitlist updated."
          },
          "400": {
            "description": "Validation failure."
          },
          "404": {
            "description": "Waitlist not found."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Update waitlist metadata and settings",
        "tags": [
          "waitlists"
        ]
      }
    },
    "/v1/workspaces/{workspaceId}/waitlists/{id}/status": {
      "patch": {
        "operationId": "WaitlistController_updateStatus",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateWaitlistStatusDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Status updated."
          },
          "400": {
            "description": "Invalid status transition."
          },
          "404": {
            "description": "Waitlist not found."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Change waitlist status",
        "tags": [
          "waitlists"
        ]
      }
    },
    "/v1/workspaces/{workspaceId}/waitlists/{waitlistId}/analytics": {
      "get": {
        "operationId": "AnalyticsController_get",
        "parameters": [
          {
            "in": "path",
            "name": "workspaceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "waitlistId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Aggregate counts, viral coefficient, top referrers + referrals",
        "tags": [
          "analytics"
        ]
      }
    },
    "/v1/workspaces/{workspaceId}/waitlists/{waitlistId}/analytics/timeline": {
      "get": {
        "operationId": "AnalyticsController_timeline",
        "parameters": [
          {
            "in": "path",
            "name": "workspaceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "waitlistId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "ISO-8601 inclusive start",
            "in": "query",
            "name": "since",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "ISO-8601 exclusive end",
            "in": "query",
            "name": "until",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Daily-bucketed signup timeline (UTC, dense — zero-count days included)",
        "tags": [
          "analytics"
        ]
      }
    },
    "/v1/workspaces/{workspaceId}/waitlists/{waitlistId}/entries": {
      "get": {
        "operationId": "EntryController_list",
        "parameters": [
          {
            "in": "path",
            "name": "workspaceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "waitlistId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 20,
              "maximum": 100,
              "minimum": 1,
              "type": "number"
            }
          },
          {
            "description": "Opaque cursor for pagination",
            "in": "query",
            "name": "cursor",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Filter by status",
            "in": "query",
            "name": "status",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Page of entries with pagination cursor."
          },
          "403": {
            "description": "Caller lacks `entry.read`, or workspace has not enabled the `rally` service."
          },
          "404": {
            "description": "Waitlist not found in this workspace."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "List entries on a waitlist (paginated)",
        "tags": [
          "entries"
        ]
      }
    },
    "/v1/workspaces/{workspaceId}/waitlists/{waitlistId}/entries/bulk": {
      "post": {
        "operationId": "EntryController_bulk",
        "parameters": [
          {
            "in": "path",
            "name": "workspaceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "waitlistId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkEntryActionDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "`{ requested, succeeded, failed, results }`. Each row in `results` carries `{ id, status: \"ok\" | \"error\", error?: { code, message } }` so a partial failure (one bad id) doesn't fail the whole batch."
          },
          "400": {
            "description": "Empty `ids`, more than 100 ids, or unknown action."
          },
          "403": {
            "description": "Caller lacks `entry.update`."
          },
          "404": {
            "description": "Waitlist not found."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Bulk-apply approve / reject / invite-to-app to multiple entries at once. Capped at 100 ids per call. Processed serially server-side; per-row results are returned so the UI can render partial successes.",
        "tags": [
          "entries"
        ]
      }
    },
