{
  "components": {
    "schemas": {
      "AcceptWorkspaceInviteDto": {
        "properties": {
          "code": {
            "description": "Invite code from the invite email / link.",
            "example": "inv_…",
            "type": "string"
          }
        },
        "required": [
          "code"
        ],
        "type": "object"
      },
      "CreatePakDto": {
        "properties": {
          "description": {
            "description": "Optional description (e.g. which service uses the key).",
            "maxLength": 500,
            "type": "string"
          },
          "name": {
            "description": "Human-readable PAK name (shown in the keys list).",
            "example": "Production agora client",
            "maxLength": 120,
            "minLength": 1,
            "type": "string"
          },
          "policy": {
            "description": "IAM-style policy. List of statements that gate the key — each scoped to a set of actions + resources.",
            "items": {
              "$ref": "#/components/schemas/PolicyStatementDto"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "name",
          "policy"
        ],
        "type": "object"
      },
      "CreateWorkspaceDto": {
        "properties": {
          "displayName": {
            "description": "Display name shown in console and on receipts.",
            "example": "Acme Corp",
            "maxLength": 128,
            "minLength": 1,
            "type": "string"
          },
          "slug": {
            "description": "URL-friendly slug. Lowercase alphanumerics, separated by hyphens. Used in URLs and as a stable handle.",
            "example": "acme-corp",
            "maxLength": 64,
            "minLength": 2,
            "type": "string"
          }
        },
        "required": [
          "slug",
          "displayName"
        ],
        "type": "object"
      },
      "CreateWorkspaceInviteDto": {
        "properties": {
          "email": {
            "description": "Optional invitee email. When set, the invite is locked to that address.",
            "example": "alice@example.com",
            "type": "string"
          },
          "expiresInHours": {
            "description": "Hours until the invite expires. Defaults to 168 (7 days).",
            "example": 168,
            "maximum": 8760,
            "minimum": 1,
            "type": "number"
          },
          "maxUses": {
            "description": "Maximum number of accepts. Defaults to 1. Use higher values for \"team link\" invites.",
            "example": 1,
            "maximum": 10000,
            "minimum": 1,
            "type": "number"
          },
          "role": {
            "description": "System role shortcut: 'owner' | 'admin' | 'member'.",
            "enum": [
              "owner",
              "admin",
              "member"
            ],
            "type": "string"
          },
          "roleId": {
            "description": "UUID of the role to grant on accept. Use to target custom roles.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "CreateWorkspaceRoleDto": {
        "properties": {
          "description": {
            "description": "Optional human-readable role description.",
            "maxLength": 256,
            "type": "string"
          },
          "name": {
            "description": "Role name. Free-form; not URL-significant.",
            "example": "BillingAdmin",
            "maxLength": 64,
            "minLength": 1,
            "type": "string"
          },
          "permissions": {
            "description": "Permission strings (`<service>.<resource>.<action>`) granted to the role.",
            "example": [
              "envoi.template.read",
              "envoi.message.read"
            ],
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "EnableWorkspaceServiceDto": {
        "properties": {
          "settings": {
            "description": "Optional per-service settings blob captured at enable time.",
            "type": "object"
          }
        },
        "type": "object"
      },
      "FeedbackResponseDto": {
        "properties": {
          "message": {
            "description": "Human-readable message",
            "example": "Email verified successfully",
            "type": "string"
          }
        },
        "required": [
          "message"
        ],
        "type": "object"
      },
      "LogoutDto": {
        "properties": {
          "refresh_token": {
            "description": "Refresh token (JWT)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "type": "string"
          }
        },
        "required": [
          "refresh_token"
        ],
        "type": "object"
      },
      "PolicyStatementDto": {
        "properties": {
          "actions": {
            "description": "Action strings the statement applies to (e.g. `agora.actor.read`). Wildcards: `agora.*`, `*`.",
            "example": [
              "agora.actor.read",
              "agora.object.read"
            ],
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "effect": {
            "description": "Whether the statement allows or denies the listed actions on the listed resources.",
            "enum": [
              "allow",
              "deny"
            ],
            "example": "allow",
            "type": "string"
          },
          "resources": {
            "description": "Resource URNs the statement applies to (e.g. `pcft:agora:community/<uuid>`). Wildcards allowed.",
            "example": [
              "pcft:agora:community/cccccccc-cccc-cccc-cccc-cccccccccccc"
            ],
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "effect",
          "actions",
          "resources"
        ],
        "type": "object"
      },
      "RefreshDto": {
        "properties": {
          "refresh_token": {
            "description": "Refresh token (JWT)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "type": "string"
          }
        },
        "required": [
          "refresh_token"
        ],
        "type": "object"
      },
      "RequestPasswordResetDto": {
        "properties": {
          "email": {
            "description": "Email address to send reset token",
            "example": "user@example.com",
            "type": "string"
          }
        },
        "required": [
          "email"
        ],
        "type": "object"
      },
      "ResetPasswordDto": {
        "properties": {
          "newPassword": {
            "description": "New password (min 8 characters)",
            "example": "MyNewPassword123",
            "type": "string"
          },
          "token": {
            "description": "6-digit reset token sent via email",
            "example": "123456",
            "type": "string"
          }
        },
        "required": [
          "token",
          "newPassword"
        ],
        "type": "object"
      },
      "SessionDto": {
        "properties": {
          "accountId": {
            "description": "Owning account identifier",
            "example": "acc_01HZY2F2B6N7M8Q9W4E6R2",
            "type": "string"
          },
          "createdAt": {
            "description": "Creation timestamp (ISO 8601)",
            "example": "2025-09-20T12:34:56.000Z",
            "format": "date-time",
            "type": "string"
          },
          "expiresAt": {
            "description": "Expiration timestamp (ISO 8601)",
            "example": "2025-09-21T12:34:56.000Z",
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "description": "Session identifier",
            "example": "sess_01HZY2G3A7M8Q9W4E6R2K1",
            "type": "string"
          },
          "ip": {
            "description": "Client IP address",
            "example": "203.0.113.42",
            "nullable": true,
            "type": "string"
          },
          "lastUsedAt": {
            "description": "Last time this session was used (ISO 8601) or null",
            "example": "2025-09-20T18:00:00.000Z",
            "format": "date-time",
            "nullable": true,
            "type": "string"
          },
          "userAgent": {
            "description": "HTTP User-Agent string",
            "example": "Mozilla/5.0 (Macintosh; Intel Mac OS X 14_5_0) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36",
            "nullable": true,
            "type": "string"
          }
        },
        "required": [
          "id",
          "accountId",
          "ip",
          "userAgent",
          "createdAt",
          "expiresAt",
          "lastUsedAt"
        ],
        "type": "object"
      },
      "SignInDto": {
        "properties": {
          "identifier": {
            "description": "Email or username",
            "example": "user@example.com",
            "type": "string"
          },
          "password": {
            "description": "User password",
            "example": "MySecurePassword123",
            "type": "string"
          },
          "sessionDuration": {
            "description": "Session duration: \"short\" (24h), \"long\" (90d), or integer seconds (3600–7776000). Defaults to 30 days.",
            "example": "short",
            "type": "object"
          }
        },
        "required": [
          "identifier",
          "password"
        ],
        "type": "object"
      },
      "SignUpDto": {
        "properties": {
          "displayName": {
            "description": "Display name",
            "example": "John Doe",
            "type": "string"
          },
          "email": {
            "description": "User email address",
            "example": "user@example.com",
            "type": "string"
          },
          "password": {
            "description": "User password (min 8 characters)",
            "example": "MySecurePassword123",
            "type": "string"
          },
          "sessionDuration": {
            "description": "Session duration: \"short\" (24h), \"long\" (90d), or integer seconds (3600–7776000). Defaults to 30 days.",
            "example": "long",
            "type": "object"
          },
          "username": {
            "description": "Unique username (letters, numbers, dot, underscore, hyphen)",
            "example": "john_doe",
            "type": "string"
          }
        },
        "required": [
          "email",
          "username",
          "password"
        ],
        "type": "object"
      },
      "TokenResponseDto": {
        "properties": {
          "access_token": {
            "description": "Access token (JWT)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "type": "string"
          },
          "expires_in": {
            "description": "Access token TTL in seconds",
            "example": 3600,
            "type": "number"
          },
          "refresh_token": {
            "description": "Refresh token (JWT)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "type": "string"
          },
          "token_type": {
            "description": "Token type",
            "example": "Bearer",
            "type": "string"
          }
        },
        "required": [
          "access_token",
          "token_type",
          "expires_in"
        ],
        "type": "object"
      },
      "UpdateMemberRoleDto": {
        "properties": {
          "role": {
            "description": "System role shortcut: 'owner' | 'admin' | 'member'. Either `roleId` or `role` must be supplied.",
            "enum": [
              "owner",
              "admin",
              "member"
            ],
            "type": "string"
          },
          "roleId": {
            "description": "UUID of the role to assign. Use this to target custom roles.",
            "example": "11111111-1111-4111-8111-111111111111",
            "type": "string"
          }
        },
        "type": "object"
      },
      "UpdatePakDto": {
        "properties": {
          "description": {
            "maxLength": 500,
            "nullable": true,
            "type": "string"
          },
          "name": {
            "maxLength": 120,
            "minLength": 1,
            "type": "string"
          },
          "policy": {
            "description": "Replaces the policy entirely if provided.",
            "items": {
              "$ref": "#/components/schemas/PolicyStatementDto"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "type": "object"
      },
      "UpdateWorkspaceDto": {
        "properties": {
          "displayName": {
            "maxLength": 128,
            "minLength": 1,
            "type": "string"
          },
          "settings": {
            "description": "Free-form workspace settings blob.",
            "type": "object"
          },
          "slug": {
            "description": "New URL-friendly slug. Same constraints as the create form. Renames are broadcast on the workspace events queue so denormalised consumers (rally-api, future product surfaces) can sync. Old URLs continue to resolve for one rename cycle.",
            "example": "acme",
            "maxLength": 64,
            "minLength": 2,
            "type": "string"
          }
        },
        "type": "object"
      },
      "UpdateWorkspaceRoleDto": {
        "properties": {
          "description": {
            "maxLength": 256,
            "type": "string"
          },
          "name": {
            "maxLength": 64,
            "minLength": 1,
            "type": "string"
          },
          "permissions": {
            "description": "Replaces the role permission set if provided. Omit to leave permissions unchanged.",
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "VerifyCodeDto": {
        "properties": {
          "code": {
            "description": "Verification code from the email link.",
            "example": "a1b2c3d4…",
            "type": "string"
          }
        },
        "required": [
          "code"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearer": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {},
    "description": "PlatformUser authentication and workspace administration for ProductCraft. Owns sign-in, sign-up, password reset, workspaces, members, invites, workspace roles, workspace-service toggles, and the introspect endpoint every other backend uses to resolve permissions.",
    "title": "Platform Auth API",
    "version": "1.0.0"
  },
  "openapi": "3.0.0",
  "paths": {
    "/.well-known/jwks.json": {
      "get": {
        "operationId": "JwksController_jwks",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "Jwks"
        ]
      }
    },
    "/v1/account": {
      "delete": {
        "operationId": "AccountController_deleteAccount",
        "parameters": [],
        "responses": {
          "204": {
            "description": ""
          }
        },
        "tags": [
          "Account"
        ]
      }
    },
    "/v1/auth/logout": {
      "post": {
        "operationId": "AuthenticationController_logout",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LogoutDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Logout successful (no content)"
          },
          "400": {
            "description": "Validation failed or invalid token"
          }
        },
        "summary": "Logout by revoking refresh token",
        "tags": [
          "authentication"
        ]
      }
    },
    "/v1/auth/logout-current": {
      "post": {
        "operationId": "AuthenticationController_logoutCurrent",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Logout successful (no content)"
          },
          "401": {
            "description": "Missing or invalid access token"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Revoke the server-side session tied to the caller’s current access token",
        "tags": [
          "authentication"
        ]
      }
    },
    "/v1/auth/password/request-reset": {
      "post": {
        "operationId": "PasswordController_requestPasswordReset",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestPasswordResetDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "Password"
        ]
      }
    },
    "/v1/auth/password/reset": {
      "post": {
        "operationId": "PasswordController_resetPassword",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetPasswordDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "Password"
        ]
      }
    },
    "/v1/auth/refresh": {
      "post": {
        "operationId": "AuthenticationController_refresh",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              }
            },
            "description": "Token response"
          },
          "400": {
            "description": "Validation failed or invalid token"
          }
        },
        "summary": "Refresh access token using refresh token",
        "tags": [
          "authentication"
        ]
      }
    },
    "/v1/auth/signin": {
      "post": {
        "operationId": "AuthenticationController_signin",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignInDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              }
            },
            "description": "Token response"
          },
          "400": {
            "description": "Validation failed"
          }
        },
        "summary": "Sign in with email/username and password",
        "tags": [
          "authentication"
        ]
      }
    },
    "/v1/auth/signup": {
      "post": {
        "operationId": "AuthenticationController_signup",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignUpDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              }
            },
            "description": "Token response"
          },
          "400": {
            "description": "Validation failed"
          }
        },
        "summary": "Create a new account and sign in",
        "tags": [
          "authentication"
        ]
      }
    },
    "/v1/introspect": {
      "get": {
        "operationId": "IntrospectController_introspect",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Introspect current user with workspace list",
        "tags": [
          "introspect"
        ]
      }
    },
    "/v1/introspect/api-key": {
      "post": {
        "operationId": "IntrospectController_introspectApiKey",
        "parameters": [
          {
            "in": "header",
            "name": "authorization",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": ""
          }
        },
        "summary": "Resolve a Platform API Key (PAK) to its workspace + IAM-style policy. Downstream services use this with a 60s LRU cache and evaluate the policy via @repo/authz-nestjs evaluatePolicy().",
        "tags": [
          "introspect"
        ]
      }
    },
    "/v1/introspect/workspaces/{workspaceId}": {
      "get": {
        "operationId": "IntrospectController_introspectWorkspace",
        "parameters": [
          {
            "in": "path",
            "name": "workspaceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Introspect caller's membership + effective policy + enabled services in a workspace",
        "tags": [
          "introspect"
        ]
      }
    },
    "/v1/session": {
      "get": {
        "operationId": "SessionController_getSessions",
        "parameters": [],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/SessionDto"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Active sessions"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "List active sessions",
        "tags": [
          "session"
        ]
      }
    },
    "/v1/verification/resend": {
      "post": {
        "operationId": "VerificationController_resend",
        "parameters": [],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeedbackResponseDto"
                }
              }
            },
            "description": "Verification email sent"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Resend verification email",
        "tags": [
          "verification"
        ]
      }
    },
    "/v1/verification/verify": {
      "post": {
        "operationId": "VerificationController_verify",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyCodeDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeedbackResponseDto"
                }
              }
            },
            "description": "Email verified successfully"
          },
          "400": {
            "description": "Invalid or expired verification code"
          }
        },
        "summary": "Verify an email code",
        "tags": [
          "verification"
        ]
      }
    },
    "/v1/workspaces": {
      "get": {
        "operationId": "WorkspaceController_listWorkspaces",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "cursor",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "List workspaces the current user belongs to",
        "tags": [
          "workspaces"
        ]
      },
      "post": {
        "operationId": "WorkspaceController_createWorkspace",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWorkspaceDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "summary": "Create a new workspace",
        "tags": [
          "workspaces"
        ]
      }
    },
    "/v1/workspaces/invites/accept": {
      "post": {
        "operationId": "WorkspaceController_acceptInvite",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
