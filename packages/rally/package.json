{
  "name": "@productcraft/rally",
  "version": "0.0.2",
  "description": "Waitlists & growth experiments — collect signups and gate access via ProductCraft Rally. Generated from the production OpenAPI spec.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup"
  },
  "keywords": [
    "productcraft",
    "sdk",
    "rally"
  ],
  "author": "ProductCraft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clauderanelagh/productcraft-node.git",
    "directory": "packages/rally"
  },
  "homepage": "https://github.com/clauderanelagh/productcraft-node/tree/main/packages/rally",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@productcraft/core": "workspace:^",
    "openapi-fetch": "^0.13.0"
  }
}
