{
  "name": "@productcraft/heimdall",
  "version": "0.0.2",
  "description": "Customer auth & EndUsers — sign-in flows, OTP, sessions for ProductCraft Heimdall. Generated from the production OpenAPI spec.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup"
  },
  "keywords": [
    "productcraft",
    "sdk",
    "heimdall"
  ],
  "author": "ProductCraft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clauderanelagh/productcraft-node.git",
    "directory": "packages/heimdall"
  },
  "homepage": "https://github.com/clauderanelagh/productcraft-node/tree/main/packages/heimdall",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@productcraft/core": "workspace:^",
    "openapi-fetch": "^0.13.0"
  }
}
