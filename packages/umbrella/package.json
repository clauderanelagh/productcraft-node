{
  "name": "productcraft",
  "version": "0.2.6",
  "description": "All-in-one Node.js / TypeScript SDK for the ProductCraft platform — Auth, Mail, Waitlist, Social, Platform-Auth, and Trawl from a single import. Install per-product packages (`@productcraft/auth`, ...) if you only need one.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "keywords": [
    "productcraft",
    "sdk",
    "auth",
    "mail",
    "waitlist",
    "social",
    "auth",
    "email",
    "waitlist",
    "openapi"
  ],
  "author": "ProductCraft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clauderanelagh/productcraft-node.git",
    "directory": "packages/umbrella"
  },
  "homepage": "https://github.com/clauderanelagh/productcraft-node",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@productcraft/social": "workspace:^",
    "@productcraft/core": "workspace:^",
    "@productcraft/mail": "workspace:^",
    "@productcraft/auth": "workspace:^",
    "@productcraft/platform-auth": "workspace:^",
    "@productcraft/waitlist": "workspace:^",
    "@productcraft/trawl": "workspace:^"
  }
}
