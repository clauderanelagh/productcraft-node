{
  "name": "@productcraft/core",
  "version": "0.1.0",
  "description": "Shared transport, auth, and config primitives for the ProductCraft SDKs. Depended on by every per-surface package.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup"
  },
  "keywords": [
    "productcraft",
    "sdk"
  ],
  "author": "ProductCraft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clauderanelagh/productcraft-node.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/clauderanelagh/productcraft-node/tree/main/packages/core",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  }
}
