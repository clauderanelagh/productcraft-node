{
  "name": "@productcraft/mail",
  "version": "0.1.0",
  "description": "Receive-and-store mail platform — template-rendered sends, mailboxes + domains + DKIM, message timeline, suppression lists, outbound webhooks via ProductCraft Mail. Generated from the production OpenAPI spec.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup"
  },
  "keywords": [
    "productcraft",
    "sdk",
    "mail"
  ],
  "author": "ProductCraft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clauderanelagh/productcraft-node.git",
    "directory": "packages/mail"
  },
  "homepage": "https://github.com/clauderanelagh/productcraft-node/tree/main/packages/mail",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@productcraft/core": "workspace:^",
    "openapi-fetch": "^0.13.0"
  }
}
